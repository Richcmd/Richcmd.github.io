<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TaskFlow V2</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Inter',sans-serif;
}

body{
  background:#0f172a;
  color:white;
  display:flex;
  min-height:100vh;
}

.sidebar{
  width:260px;
  background:#111827;
  border-right:1px solid rgba(255,255,255,0.08);
  padding:25px;
}

.logo{
  font-size:30px;
  font-weight:700;
  color:#38bdf8;
  margin-bottom:40px;
}

.menu{
  display:flex;
  flex-direction:column;
  gap:14px;
}

.menu button{
  background:#1e293b;
  border:none;
  color:white;
  padding:14px;
  border-radius:16px;
  cursor:pointer;
  transition:0.2s;
  text-align:left;
}

.menu button:hover{
  background:#38bdf8;
  color:black;
}

.main{
  flex:1;
  padding:35px;
}

.page{
  display:none;
}

.page.active{
  display:block;
}

h1{
  font-size:34px;
  margin-bottom:30px;
}

.stats-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.card{
  background:#1e293b;
  padding:24px;
  border-radius:24px;
}

.card small{
  opacity:0.7;
}

.card h2{
  color:#38bdf8;
  margin-top:10px;
  font-size:32px;
}

.topbar{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:14px;
  margin-bottom:25px;
}

input,
select,
textarea{
  background:#1e293b;
  border:none;
  border-radius:16px;
  padding:14px;
  color:white;
  width:100%;
  outline:none;
}

textarea{
  min-height:220px;
  resize:vertical;
}

button.primary{
  background:#38bdf8;
  color:black;
  border:none;
  border-radius:16px;
  font-weight:600;
  cursor:pointer;
}

.tasks-grid,
.shift-grid,
.template-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:20px;
}

.task,
.shift,
.template{
  background:#1e293b;
  border-radius:24px;
  padding:22px;
}

.task-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:16px;
}

.badge{
  padding:6px 12px;
  border-radius:40px;
  font-size:12px;
  font-weight:700;
}

.daily{
  background:#22c55e;
  color:black;
}

.weekly{
  background:#f59e0b;
  color:black;
}

.monthly{
  background:#a855f7;
}

.points{
  color:#38bdf8;
  margin-top:10px;
  font-weight:700;
}

.task-footer{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-top:18px;
}

.delete-btn{
  background:#ef4444;
  border:none;
  color:white;
  padding:10px 14px;
  border-radius:12px;
  cursor:pointer;
}

.done{
  opacity:0.55;
}

.done h3{
  text-decoration:line-through;
}

.reward-box{
  background:#1e293b;
  padding:24px;
  border-radius:24px;
  margin-bottom:30px;
}

.progress-wrapper{
  width:100%;
  height:12px;
  background:#0f172a;
  border-radius:999px;
  overflow:hidden;
  margin-top:14px;
}

.progress{
  height:100%;
  width:0%;
  background:#38bdf8;
}

.chart-box{
  background:#1e293b;
  padding:24px;
  border-radius:24px;
}

.status-green{
  border-left:6px solid #22c55e;
}

.status-yellow{
  border-left:6px solid #eab308;
}

.status-orange{
  border-left:6px solid #f97316;
}

.status-red{
  border-left:6px solid #ef4444;
}

.template button{
  margin-top:16px;
  width:100%;
  padding:14px;
}

@media(max-width:900px){
  body{
    flex-direction:column;
  }

  .sidebar{
    width:100%;
  }
}
</style>
</head>
<body>

<div class="sidebar">
  <div class="logo">TaskFlow</div>

  <div class="menu">
    <button onclick="showPage('dashboardPage')">📊 Dashboard</button>
    <button onclick="showPage('tasksPage')">✅ Taken</button>
    <button onclick="showPage('templatesPage')">📦 Templates</button>
    <button onclick="showPage('shiftsPage')">🧾 Shifts</button>
    <button onclick="showPage('notesPage')">📝 Notities</button>
  </div>
</div>

<div class="main">

  <div class="page active" id="dashboardPage">
    <h1>Dashboard</h1>

    <div class="stats-grid">
      <div class="card">
        <small>Totaal Punten</small>
        <h2 id="totalPoints">0</h2>
      </div>

      <div class="card">
        <small>Voltooide Taken</small>
        <h2 id="completedTasks">0</h2>
      </div>

      <div class="card">
        <small>Productiviteit</small>
        <h2 id="productivity">0%</h2>
      </div>

      <div class="card">
        <small>Rank</small>
        <h2 id="rank">Beginner</h2>
      </div>
    </div>

    <div class="reward-box">
      <h3>🎯 Progressie</h3>
      <p>Volgende rank: <span id="nextRank">Focused</span></p>

      <div class="progress-wrapper">
        <div class="progress" id="progressBar"></div>
      </div>
    </div>

    <div class="chart-box">
      <canvas id="productivityChart"></canvas>
    </div>
  </div>

  <div class="page" id="tasksPage">
    <h1>Taken</h1>

    <div class="topbar">
      <input type="text" id="taskTitle" placeholder="Taak titel">

      <input type="time" id="taskTime">

      <input type="number" id="taskPoints" placeholder="Punten">

      <select id="taskRepeat">
        <option value="daily">Dagelijks</option>
        <option value="weekly">Wekelijks</option>
        <option value="monthly">Maandelijks</option>
      </select>

      <button class="primary" onclick="addTask()">Toevoegen</button>
    </div>

    <div class="tasks-grid" id="taskList"></div>
  </div>

  <div class="page" id="templatesPage">
    <h1>Templates</h1>

    <div class="template-grid">
      <div class="template">
        <h3>🌅 Morning Routine</h3>
        <p>Start je dag goed met productieve routines.</p>
        <button class="primary" onclick="loadMorningRoutine()">Inladen</button>
      </div>

      <div class="template">
        <h3>🏋️ Gym Routine</h3>
        <p>Sporttaken en gezondheid routines.</p>
        <button class="primary" onclick="loadGymRoutine()">Inladen</button>
      </div>

      <div class="template">
        <h3>🧹 Weekly Reset</h3>
        <p>Wekelijkse schoonmaak en administratie.</p>
        <button class="primary" onclick="loadWeeklyRoutine()">Inladen</button>
      </div>
    </div>
  </div>

  <div class="page" id="shiftsPage">
    <h1>Shift Rapportage</h1>

    <div class="topbar">
      <input type="text" id="shiftTitle" placeholder="Shift titel">

      <select id="shiftStatus">
        <option value="green">🟢 Groen</option>
        <option value="yellow">🟡 Geel</option>
        <option value="orange">🟠 Oranje</option>
        <option value="red">🔴 Rood</option>
      </select>

      <input type="number" id="shiftEnergy" placeholder="Energie 1-10">

      <button class="primary" onclick="addShift()">Opslaan</button>
    </div>

    <textarea id="shiftNotes" placeholder="Shift notities..."></textarea>

    <br><br>

    <div class="shift-grid" id="shiftList"></div>
  </div>

  <div class="page" id="notesPage">
    <h1>Notities</h1>

    <textarea id="notesArea" placeholder="Schrijf hier je notities..."></textarea>
  </div>

</div>

<script>
const tasks = JSON.parse(localStorage.getItem('tasks')) || [];
const shifts = JSON.parse(localStorage.getItem('shifts')) || [];

function saveData(){
  localStorage.setItem('tasks', JSON.stringify(tasks));
  localStorage.setItem('shifts', JSON.stringify(shifts));
}

function showPage(id){
  document.querySelectorAll('.page').forEach(page => {
    page.classList.remove('active');
  });

  document.getElementById(id).classList.add('active');
}

function addTask(){
  const title = document.getElementById('taskTitle').value;
  const time = document.getElementById('taskTime').value;
  const points = Number(document.getElementById('taskPoints').value);
  const repeat = document.getElementById('taskRepeat').value;

  if(!title) return;

  tasks.push({
    id: Date.now(),
    title,
    time,
    points,
    repeat,
    completed:false,
    created:new Date().toISOString()
  });

  saveData();
  renderTasks();
  updateDashboard();

  document.getElementById('taskTitle').value='';
  document.getElementById('taskPoints').value='';
}

function renderTasks(){
  const taskList = document.getElementById('taskList');

  taskList.innerHTML='';

  tasks.sort((a,b)=>a.time.localeCompare(b.time));

  tasks.forEach(task=>{
    const div = document.createElement('div');

    div.className = `task ${task.completed ? 'done' : ''}`;

    div.innerHTML = `
      <div class="task-top">
        <span class="badge ${task.repeat}">${task.repeat}</span>

        <input type="checkbox"
          ${task.completed ? 'checked' : ''}
          onchange="toggleTask(${task.id})">
      </div>

      <h3>${task.title}</h3>

      <p>⏰ ${task.time || 'Geen tijd'}</p>

      <div class="points">⭐ ${task.points} punten</div>

      <div class="task-footer">
        <small>${new Date(task.created).toLocaleDateString()}</small>

        <button class="delete-btn" onclick="deleteTask(${task.id})">
          Verwijderen
        </button>
      </div>
    `;

    taskList.appendChild(div);
  });
}

function toggleTask(id){
  const task = tasks.find(t=>t.id===id);

  task.completed = !task.completed;

  saveData();
  renderTasks();
  updateDashboard();
}

function deleteTask(id){
  const index = tasks.findIndex(t=>t.id===id);

  tasks.splice(index,1);

  saveData();
  renderTasks();
  updateDashboard();
}

function addShift(){
  const title = document.getElementById('shiftTitle').value;
  const status = document.getElementById('shiftStatus').value;
  const energy = document.getElementById('shiftEnergy').value;
  const notes = document.getElementById('shiftNotes').value;

  if(!title) return;

  shifts.push({
    title,
    status,
    energy,
    notes,
    date:new Date().toISOString()
  });

  saveData();
  renderShifts();

  document.getElementById('shiftTitle').value='';
  document.getElementById('shiftEnergy').value='';
  document.getElementById('shiftNotes').value='';
}

function renderShifts(){
  const shiftList = document.getElementById('shiftList');

  shiftList.innerHTML='';

  [...shifts].reverse().forEach(shift=>{
    const div = document.createElement('div');

    div.className = `shift status-${shift.status}`;

    div.innerHTML = `
      <h3>${shift.title}</h3>

      <p>⚡ Energie: ${shift.energy}/10</p>

      <p style="margin-top:10px;opacity:0.8;">
        ${shift.notes}
      </p>

      <br>

      <small>
        ${new Date(shift.date).toLocaleDateString()}
      </small>
    `;

    shiftList.appendChild(div);
  });
}

function updateDashboard(){
  const completed = tasks.filter(t=>t.completed);

  const totalPoints = completed.reduce((sum,t)=>sum+t.points,0);

  document.getElementById('totalPoints').innerText = totalPoints;

  document.getElementById('completedTasks').innerText = completed.length;

  const productivity = tasks.length
    ? Math.round((completed.length/tasks.length)*100)
    : 0;

  document.getElementById('productivity').innerText = productivity + '%';

  let rank = 'Beginner';
  let nextRank = 'Focused';
  let progress = 10;

  if(totalPoints >= 500){
    rank = 'Focused';
    nextRank = 'Productive';
    progress = 40;
  }

  if(totalPoints >= 2000){
    rank = 'Productive';
    nextRank = 'Elite';
    progress = 75;
  }

  if(totalPoints >= 5000){
    rank = 'Elite';
    nextRank = 'Max';
    progress = 100;
  }

  document.getElementById('rank').innerText = rank;
  document.getElementById('nextRank').innerText = nextRank;

  document.getElementById('progressBar').style.width = progress + '%';

  updateChart(productivity,totalPoints);
}

let productivityChart;

function updateChart(productivity,points){
  const ctx = document.getElementById('productivityChart');

  if(productivityChart){
    productivityChart.destroy();
  }

  productivityChart = new Chart(ctx, {
    type:'bar',
    data:{
      labels:['Productiviteit','Punten'],
      datasets:[{
        label:'Statistieken',
        data:[productivity,points],
        borderWidth:2
      }]
    },
    options:{
      responsive:true,
      plugins:{
        legend:{
          labels:{
            color:'white'
          }
        }
      },
      scales:{
        y:{
          ticks:{
            color:'white'
          }
        },
        x:{
          ticks:{
            color:'white'
          }
        }
      }
    }
  });
}

function loadMorningRoutine(){
  tasks.push(
    {
      id:Date.now()+1,
      title:'Bed opmaken',
      time:'07:00',
      points:20,
      repeat:'daily',
      completed:false,
      created:new Date().toISOString()
    },
    {
      id:Date.now()+2,
      title:'Water drinken',
      time:'07:10',
      points:10,
      repeat:'daily',
      completed:false,
      created:new Date().toISOString()
    }
  );

  saveData();
  renderTasks();
  updateDashboard();
}

function loadGymRoutine(){
  tasks.push(
    {
      id:Date.now()+3,
      title:'Sportschool',
      time:'18:00',
      points:80,
      repeat:'weekly',
      completed:false,
      created:new Date().toISOString()
    },
    {
      id:Date.now()+4,
      title:'Eiwitshake',
      time:'20:00',
      points:20,
      repeat:'weekly',
      completed:false,
      created:new Date().toISOString()
    }
  );

  saveData();
  renderTasks();
  updateDashboard();
}

function loadWeeklyRoutine(){
  tasks.push(
    {
      id:Date.now()+5,
      title:'Kamer schoonmaken',
      time:'11:00',
      points:60,
      repeat:'weekly',
      completed:false,
      created:new Date().toISOString()
    },
    {
      id:Date.now()+6,
      title:'Administratie',
      time:'13:00',
      points:40,
      repeat:'monthly',
      completed:false,
      created:new Date().toISOString()
    }
  );

  saveData();
  renderTasks();
  updateDashboard();
}

const notesArea = document.getElementById('notesArea');

notesArea.value = localStorage.getItem('notes') || '';

notesArea.addEventListener('input',()=>{
  localStorage.setItem('notes',notesArea.value);
});

renderTasks();
renderShifts();
updateDashboard();
</script>

</body>
</html>
```
