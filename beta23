<script>

let settings = JSON.parse(localStorage.getItem('settings')) || {
  username: 'Gebruiker',
  haccpHours: 3.5,
  language: 'nl'
};

let tasks = JSON.parse(localStorage.getItem('tasks')) || [];
let agfItems = JSON.parse(localStorage.getItem('agfItems')) || [];
let reports = JSON.parse(localStorage.getItem('reports')) || [];
let notifications = JSON.parse(localStorage.getItem('notifications')) || [];

const translations = {
  nl: {
    welcome: 'Welkom terug',
    system: 'Slim retail management systeem'
  },
  en: {
    welcome: 'Welcome back',
    system: 'Smart retail management system'
  }
};

function saveAll(){
  localStorage.setItem('tasks', JSON.stringify(tasks));
  localStorage.setItem('agfItems', JSON.stringify(agfItems));
  localStorage.setItem('reports', JSON.stringify(reports));
  localStorage.setItem('notifications', JSON.stringify(notifications));
  localStorage.setItem('settings', JSON.stringify(settings));

  updateDashboard();
}

function toggleSidebar(){
 document.getElementById('sidebar').classList.toggle('closed');
}

function showTab(tabName){
 document.querySelectorAll('.tab-content').forEach(tab=>tab.classList.add('hidden'));
 document.getElementById(tabName).classList.remove('hidden');

 document.querySelectorAll('[id^="tab-"]').forEach(btn=>btn.classList.remove('active-tab'));
 document.getElementById('tab-'+tabName).classList.add('active-tab');

 if(window.innerWidth < 1024){
  document.getElementById('sidebar').classList.add('closed');
 }
}

function updateDashboard(){

 document.getElementById('taskCount').innerText = tasks.length;
 document.getElementById('agfCount').innerText = agfItems.length;
 document.getElementById('reportCount').innerText = reports.length;

 const completedTasks = tasks.filter(t=>t.status==='Voldaan').length;
 const productivity = tasks.length ? Math.round((completedTasks/tasks.length)*100) : 0;

 const totalMinutes = tasks.reduce((sum,t)=>sum + Number(t.duration || 0),0);
 const workPressure = Math.round((totalMinutes / (settings.haccpHours*60))*100);

 const greeting = document.querySelector('h2');
 greeting.innerHTML = `${translations[settings.language].welcome}, ${settings.username} 👋`;

 const sub = greeting.parentElement.querySelector('p');
 sub.innerText = translations[settings.language].system;

 renderTaskAnalytics(productivity, workPressure);
 renderAGFInsights();
 renderNotifications();
}

function translatePage(lang){
 settings.language = lang;
 saveAll();
}

function toggleNotifications(){
 showTab('dashboard');
 alert(`${notifications.length} meldingen beschikbaar`);
}

function addNotification(text){
 notifications.unshift({
  id: Date.now(),
  text,
  time: new Date().toLocaleTimeString()
 });

 if(notifications.length > 15){
  notifications.pop();
 }

 saveAll();
}

function renderNotifications(){
 let focus = document.querySelector('.space-y-4');
 if(!focus) return;
}

function addTask(){
 const title = document.getElementById('taskTitle').value;
 const priority = document.getElementById('taskPriority').value;
 const duration = document.getElementById('taskDuration').value;

 if(!title || !duration) return;

 tasks.unshift({
  id: Date.now(),
  title,
  priority,
  duration,
  status: 'Open',
  created: new Date().toLocaleString()
 });

 addNotification(`Nieuwe HACCP taak: ${title}`);

 document.getElementById('taskTitle').value='';
 document.getElementById('taskDuration').value='';

 renderTasks();
 saveAll();
}

function renderTasks(){
 const container = document.getElementById('taskList');
 container.innerHTML='';

 tasks.forEach(task=>{

 const statusColor = task.status === 'Voldaan'
 ? 'text-green-400'
 : task.status === 'Uitgesteld'
 ? 'text-orange-400'
 : task.status === 'Overgeslagen'
 ? 'text-red-400'
 : 'text-blue-400';

 container.innerHTML += `
 <div class="glass rounded-3xl p-5 flex flex-col xl:flex-row justify-between gap-5">

 <div>
 <div class="flex flex-wrap items-center gap-3 mb-3">
 <h3 class="text-2xl font-bold">${task.title}</h3>
 <span class="bg-orange-500/20 text-orange-400 px-3 py-1 rounded-full text-xs">${task.priority}</span>
 <span class="${statusColor} font-bold">${task.status}</span>
 </div>

 <p class="text-gray-400">${task.duration} minuten</p>
 <p class="text-gray-500 text-sm mt-2">${task.created}</p>
 </div>

 <div class="flex flex-wrap gap-3">
 <button onclick="changeTaskStatus(${task.id}, 'Voldaan')" class="bg-green-500/20 text-green-400 px-4 py-2 rounded-xl">Voldaan</button>
 <button onclick="changeTaskStatus(${task.id}, 'Uitgesteld')" class="bg-orange-500/20 text-orange-400 px-4 py-2 rounded-xl">Uitstellen</button>
 <button onclick="changeTaskStatus(${task.id}, 'Overgeslagen')" class="bg-red-500/20 text-red-400 px-4 py-2 rounded-xl">Overslaan</button>
 <button onclick="editTask(${task.id})" class="bg-blue-500/20 text-blue-400 px-4 py-2 rounded-xl">Bewerken</button>
 <button onclick="deleteTask(${task.id})" class="bg-red-500/20 text-red-400 px-4 py-2 rounded-xl">Verwijderen</button>
 </div>
 </div>
 `;
 });
}

function changeTaskStatus(id,status){
 const task = tasks.find(t=>t.id===id);
 if(task){
  task.status = status;
  addNotification(`${task.title} → ${status}`);
  renderTasks();
  saveAll();
 }
}

function editTask(id){
 const task = tasks.find(t=>t.id===id);
 const newTitle = prompt('Nieuwe titel', task.title);
 if(newTitle){
  task.title = newTitle;
  renderTasks();
  saveAll();
 }
}

function deleteTask(id){
 tasks = tasks.filter(t=>t.id!==id);
 renderTasks();
 saveAll();
}

function addAGF(){
 const product = document.getElementById('agfProduct').value;
 const type = document.getElementById('agfType').value;

 if(!product) return;

 agfItems.unshift({
  id: Date.now(),
  product,
  type,
  created: new Date().toLocaleString()
 });

 addNotification(`AGF melding: ${product}`);

 document.getElementById('agfProduct').value='';

 renderAGF();
 saveAll();
}

function renderAGF(){
 const container = document.getElementById('agfList');
 container.innerHTML='';

 const productMap = {};

 agfItems.forEach(item=>{

 if(!productMap[item.product]){
  productMap[item.product] = [];
 }

 productMap[item.product].push(item.type);

 container.innerHTML += `
 <div class="glass rounded-3xl p-5 flex flex-col xl:flex-row justify-between gap-4">
 <div>
 <h3 class="text-2xl font-bold mb-2">${item.product}</h3>
 <p class="text-gray-400">${item.type}</p>
 <p class="text-gray-500 text-sm mt-2">${item.created}</p>
 </div>

 <div class="flex flex-wrap gap-3">
 <button onclick="editAGF(${item.id})" class="bg-blue-500/20 text-blue-400 px-4 py-2 rounded-xl">Bewerken</button>
 <button onclick="deleteAGF(${item.id})" class="bg-red-500/20 text-red-400 px-4 py-2 rounded-xl">Verwijderen</button>
 </div>
 </div>
 `;
 });

 renderAGFRecommendations(productMap);
}

function renderAGFRecommendations(productMap){
 let existing = document.getElementById('recommendationPanel');
 if(existing) existing.remove();

 const section = document.getElementById('agf');
 const panel = document.createElement('div');
 panel.id = 'recommendationPanel';
 panel.className = 'glass rounded-3xl p-6 mt-8';

 let html = `<h3 class="text-3xl font-black mb-6">Bestel Overzicht</h3><div class="space-y-4">`;

 Object.keys(productMap).forEach(product=>{
  const entries = productMap[product];

  const overstock = entries.filter(e=>e==='Overvoorraad').length;
  const shortage = entries.filter(e=>e==='Leeg schap').length;

  let advice = 'Stabiel';
  let color = 'text-green-400';

  if(overstock > shortage){
   advice = 'Bestelling verlagen';
   color = 'text-red-400';
  }

  if(shortage > overstock){
   advice = 'Extra bijbestellen';
   color = 'text-orange-400';
  }

  html += `
  <div class="bg-white/5 rounded-2xl p-5 flex justify-between items-center">
  <div>
  <h4 class="text-xl font-bold">${product}</h4>
  <p class="text-gray-400">${entries.length} meldingen</p>
  </div>
  <div class="${color} font-bold">${advice}</div>
  </div>
  `;
 });

 html += '</div>';
 panel.innerHTML = html;
 section.appendChild(panel);
}

