function addReport(){
 const title = document.getElementById('reportTitle').value;
 const status = document.getElementById('reportStatus').value;
 const note = document.getElementById('reportNote').value;

 if(!title || !note) return;

 reports.unshift({
  id: Date.now(),
  title,
  status,
  note,
  time: new Date().toLocaleString()
 });

 addNotification(`Nieuw rapport: ${title}`);

 renderReports();
 saveAll();

 reportTitle.value='';
 reportNote.value='';
}

function renderReports(){
 const container = document.getElementById('reportList');
 container.innerHTML='';

 reports.forEach(report=>{

 let border = 'border-green-400';

 if(report.status==='Geel') border='border-yellow-400';
 if(report.status==='Oranje') border='border-orange-400';
 if(report.status==='Rood') border='border-red-400';

 container.innerHTML += `
 <div class="glass rounded-3xl p-6 border-l-4 ${border}">
 <div class="flex flex-col xl:flex-row justify-between gap-4">
 <div>
 <h3 class="text-2xl font-bold">${report.title}</h3>
 <p class="text-gray-400 mt-3">${report.note}</p>
 </div>

 <div>
 <div class="text-sm text-gray-500">${report.time}</div>
 </div>
 </div>

 <div class="flex flex-wrap gap-3 mt-6">
 <button onclick="editReport(${report.id})" class="bg-blue-500/20 text-blue-400 px-4 py-2 rounded-xl">Bewerken</button>
 <button onclick="deleteReport(${report.id})" class="bg-red-500/20 text-red-400 px-4 py-2 rounded-xl">Verwijderen</button>
 </div>
 </div>
 `;
 });
}

